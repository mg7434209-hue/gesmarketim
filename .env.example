# =============================================================================
# GES MARKETİM — root .env.example
# Copy to .env (root) for local convenience; each workspace also has its own.
# Railway: set these as environment variables in the service settings.
# =============================================================================

# --- Backend ---
NODE_ENV=development
PORT=3000

# PostgreSQL connection string (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgres://user:password@localhost:5432/gesmarketim

# CORS — comma-separated list of allowed origins for the API.
# In production set to https://gesmarketim.com (and any preview domains).
CORS_ORIGIN=http://localhost:5173

# Admin auth — admin panel login (/admin) + HMAC-signed session cookie.
ADMIN_SESSION_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Active tenant (multi-tenant root).
TENANT_SLUG=gesmarketim

# Image storage — URL paste always works; file upload needs Cloudinary keys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=gesmarketim

# Storefront commercial settings (optional — defaults baked in).
FREE_SHIPPING_THRESHOLD=7500
FLAT_SHIPPING_COST=350

# Payment — bank transfer + cash on delivery work out of the box.
# Card (iyzico) activates only when both IYZICO keys are set.
PAYMENT_BANK_TRANSFER_ENABLED=true
BANK_NAME=
BANK_ACCOUNT_HOLDER=GES MARKETİM
BANK_IBAN=
PAYMENT_COD_ENABLED=true
PAYMENT_CARD_ENABLED=true
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
PUBLIC_SITE_URL=http://localhost:5173
PAYMENT_CALLBACK_BASE=http://localhost:3000

# --- Frontend ---
# Public API base URL the frontend will call.
# In production this points to the backend service / same-origin /api.
VITE_API_URL=http://localhost:3000
# Cart/checkout shipping estimate (keep in sync with backend values above).
VITE_FREE_SHIPPING_THRESHOLD=7500
VITE_FLAT_SHIPPING_COST=350
