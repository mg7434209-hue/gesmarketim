# =============================================================================
# GES MARKETİM — root .env.example
# Copy to .env (root) for local convenience; each workspace also has its own.
# Railway: set these as environment variables in the service settings.
# =============================================================================

# --- Backend ---
NODE_ENV=development
PORT=3000

# PostgreSQL connection string (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgres://user:password@localhost:5432/gesmarketim

# CORS — comma-separated list of allowed origins for the API.
# In production set to https://gesmarketim.com (and any preview domains).
CORS_ORIGIN=http://localhost:5173

# Admin auth (placeholder — fill in when admin auth is implemented)
ADMIN_SESSION_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# --- Frontend ---
# Public API base URL the frontend will call.
# In production this points to the backend service / same-origin /api.
VITE_API_URL=http://localhost:3000
