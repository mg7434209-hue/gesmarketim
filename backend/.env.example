# Backend env

NODE_ENV=development
PORT=3000

# PostgreSQL — Railway provides DATABASE_URL automatically when you attach the PG plugin.
DATABASE_URL=postgres://user:password@localhost:5432/gesmarketim

# Comma-separated list of allowed CORS origins.
# Production: https://gesmarketim.com
CORS_ORIGIN=http://localhost:5173

# Admin auth (placeholder — fill in when admin login is implemented)
ADMIN_SESSION_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
