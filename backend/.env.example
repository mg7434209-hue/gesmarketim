# Backend env

NODE_ENV=development
PORT=3000

# PostgreSQL — Railway provides DATABASE_URL automatically when you attach the PG plugin.
DATABASE_URL=postgres://user:password@localhost:5432/gesmarketim

# Comma-separated list of allowed CORS origins.
# Production: https://gesmarketim.com
CORS_ORIGIN=http://localhost:5173

# Admin auth — admin panel login (/admin) + HMAC-signed session cookie.
# Use a long random string for the secret in production.
ADMIN_SESSION_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Customer accounts — signs storefront login session cookies (HMAC).
# Use a long random string in production. Falls back to ADMIN_SESSION_SECRET.
CUSTOMER_SESSION_SECRET=change-me-in-production

# Active tenant (multi-tenant root). Defaults to "gesmarketim".
TENANT_SLUG=gesmarketim

# --- Image storage (admin product images) ---
# Pasting image URLs always works. File upload from the admin activates only
# when all three Cloudinary keys are present.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=gesmarketim

# --- Supplier feed scheduler (optional) ---
# Periodically syncs suppliers that have a feed URL in their syncConfig.
# Off by default so deployments without feeds never make outbound requests.
# Configure a supplier's feed from the admin panel (syncConfig.feedUrl +
# intervalMinutes). Set lastSyncedAt/lastResult are written automatically.
SYNC_SCHEDULER_ENABLED=false
SYNC_SCHEDULER_TICK_MINUTES=15

# Storefront commercial settings (optional — sensible defaults baked in).
# Free shipping at/above this subtotal; otherwise FLAT_SHIPPING_COST applies.
FREE_SHIPPING_THRESHOLD=7500
FLAT_SHIPPING_COST=350

# --- Payment ---
# Bank transfer (havale/EFT) — shown to the customer on the confirmation page.
PAYMENT_BANK_TRANSFER_ENABLED=true
BANK_NAME=
BANK_ACCOUNT_HOLDER=GES MARKETİM
BANK_IBAN=
# Cash on delivery (kapıda ödeme).
PAYMENT_COD_ENABLED=true
# Card payments via iyzico. The "card" method is only offered when BOTH keys
# are set. Use sandbox keys/URL while testing.
PAYMENT_CARD_ENABLED=true
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Public origin used to build the iyzico callback + post-payment redirect.
# Defaults: callback uses the request host; redirect uses CORS_ORIGIN[0].
PUBLIC_SITE_URL=http://localhost:5173
PAYMENT_CALLBACK_BASE=http://localhost:3000

# --- Order notification emails ---
# Sends an admin alert + a customer confirmation when an order is placed.
# Activates only when SMTP_HOST + SMTP_USER + SMTP_PASS are all set; otherwise
# emails are skipped silently. Works with any SMTP provider.
# Gmail: create an App Password (requires 2FA) and use it as SMTP_PASS.
SMTP_HOST=
SMTP_PORT=587
# secure=true for port 465 (implicit TLS); leave blank to auto-detect from port.
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# From header (e.g. "GES MARKETİM <gesmarketim@gmail.com>"). Defaults to SMTP_USER.
MAIL_FROM=
# Where the new-order alert is sent (comma-separated). Defaults to MAIL_FROM/SMTP_USER.
ORDER_NOTIFY_EMAIL=
