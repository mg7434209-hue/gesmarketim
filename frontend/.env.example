# Frontend env (Vite reads VITE_* vars at build/dev time)

# Base URL of the backend API.
# In dev, Vite proxies /api → this URL so you can fetch('/api/...') directly.
VITE_API_URL=http://localhost:3000

# Shipping estimate shown in the cart/checkout summary. The backend is the
# source of truth at order creation; keep these in sync with the backend's
# FREE_SHIPPING_THRESHOLD / FLAT_SHIPPING_COST for a matching preview.
VITE_FREE_SHIPPING_THRESHOLD=7500
VITE_FLAT_SHIPPING_COST=350
